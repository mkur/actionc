; Force original compiler code origin to $3000.
SET $491=$3000
SET $E=$3000

MODULE

BYTE gb
CARD gw
INT gi

PROC LocalArrays()
  BYTE i
  BYTE ARRAY bytes(4)
  CARD ARRAY words(3)
  INT ARRAY nums(2)

  i = 1

  bytes(0) = $11
  bytes(1) = $22
  gb = bytes(i)

  words(0) = $1234
  words(i) = $5678
  gw = words(i)

  nums(0) = -2
  nums(i) = -3
  gi = nums(0)
RETURN

PROC Main()
  LocalArrays()
RETURN

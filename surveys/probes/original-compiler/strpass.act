; Force original compiler code origin to $3000.
SET $491=$3000
SET $E=$3000

DEFINE STRING="CHAR ARRAY"

MODULE

STRING hello(0)="HELLO"
CHAR ARRAY raw(4)="DATA"

BYTE a0, a1, ai, b0, b1

PROC Take(STRING s, BYTE i)
  a0 = s(0)
  a1 = s(1)
  ai = s(i)
RETURN

PROC TakeRaw(CHAR ARRAY s)
  b0 = s(0)
  b1 = s(1)
RETURN

PROC Main()
  Take(hello, 4)
  TakeRaw(raw)
RETURN

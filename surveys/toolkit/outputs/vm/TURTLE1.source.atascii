SET $491=$3000øSET $E=$3000øøINCLUDE "D:TURTLE.ACT"øøPROC TurtleDemo()øø  BYTE i=[0]øø  Graphics(7)ø  PrintE("This is a demo of the Turtle Graphics")ø  PrintE("routines on the ACTION! Toolkit disk")ø  DOø    SetTurtle(100,55,100)ø    FOR i=0 TO 100ø      DO  ø      color=(i MOD 3)+1ø      Forward(50)ø      Left(100)ø      ODø    SetTurtle(85,42,100)ø    FOR i=0 TO 200ø      DO  ø      color=(i MOD 3)+1ø      Forward(20)ø      Left(100)ø      ODø  ODøRETURNøø
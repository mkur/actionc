SET $491=$3000øSET $E=$3000øø; Copyright 1983 by Action Computer Servicesø; All Rights Reservedø; last modified July, 1984øøMODULE ; KAL3.ACTøøDEFINE STRING="CHAR ARRAY"øøSET $E=$CBøSET $F=0øøBYTE ARRAY lineøøSET $E=$5000øSET $491=$5000øøBYTE low=line,ø     high=line+1,ø     x0=$D6,ø     y0=$D7,ø     x1=$D8,ø     y1=$D9,ø     t=$DAøøCARD aXI,bXI,cXI,aYI,bYI,cYI, ;initialø     aX,aY,bX,bY,cX,cY,       ;plotø     xA,yA,xB,yB,xC,yC,       ;eraseø     period,npts,ø     cntP,cntE,ystart,ytopøøBYTE ARRAY mask1(0)=[$80 $40 $20 $10 $8 $4 $2 $1],ø           mask2(0)=[$7F $BF $DF $EF $F7 $FB $FD $FE],ø           yLocL(129),ø           yLocH(129),ø           rsh3(256)øø;************************************ø;Set up plot and erase values.ø;************************************øøPROC InitP()øø  aX=aXIø  bX=bXIø  cX=cXIø  aY=aYIø  bY=bYIø  cY=cYIø  cntP=periodø  xA=aXIø  yA=aYIø  xB=bXIø  yB=bYIø  xC=cXIø  yC=cYIø  cntE=periodøRETURNøø;************************************ø;Set up the special display listø;************************************øøPROC InitGr8()øø  BYTE low,high,i,ø       memCtl=$D400,memCtlS=$22Føø  CARD next=low,RAMTOP=$69,ø       DLc=$D402,DLs=$230,ø       MEMTOP=$2E5,K32=[32],jøø  CARD ARRAY dløø  ; setup our special DL with invertedø  ; bottom.  Tricky, thanks Sheldonøø  Graphics(17)ø  SetColor(1,0,15)ø  SetColor(2,0,0)ø  memCtlS=0ø  memCtl=0 ; turn off displayø  ytop=(RAMTOP&$F000)-$1000ø  ystart=ytop+512ø  Zero(ytop,$1000) ; clear displayø  DLs=ystart-$400ø  MEMTOP=DLs-1ø  dl=DLsø  dl^=$70ø  dl==+1ø  dl^=$4F ; load scan counterø  dl==+1ø  dl^=ystartø  dl==+2ø  FOR i=1 TO 110 STEP 2ø    DOø    dl^=$F0Fø    dl==+2ø    ODø  dl^=$F   ø  dl==+1ø  next=ystart + 111*K32ø  FOR i=0 TO 111ø    DOø    dl^=$4Fø    dl==+1ø    dl^=nextø    next=next - 32ø    dl==+2ø    ODø  dl^=$41ø  dl==+1ø  dl^=DLsø  DLc=DLsø  memCtlS=$21 ; turn display onø  next=ytopø  FOR i=0 TO 128ø    DOø    yLocL(i)=lowø    yLocH(i)=highø    next ==+ 32ø    ODø  FOR j=0 TO 255ø    DOø    rsh3(j)=j RSH 3ø    ODøRETURNøø;************************************ø;Special plotø;************************************øøPROC Plot8=*(BYTE x,y)øø  BYTE x1=$A0, y1=$A1øø  low=yLocL(y1)ø  high=yLocH(y1)ø  t=rsh3(x1)ø  line(t) ==% mask1(x1&7)øRETURNøø;************************************ø;Special eraseø;************************************øøPROC Erase8=*(BYTE x,y)øø  BYTE x1=$A0, y1=$A1øø  low=yLocL(y1)ø  high=yLocH(y1)ø  t=rsh3(x1)ø  line(t) ==& mask2(x1&7)øRETURNøø;************************************ø;Plot pointsø;************************************øøPROC GenP()øø  BYTE x=aX+1,ø       y=aY+1,ø       ATRACT=$4Døø  aX=(aX+bX)!bXø  aY=(aY+bY)!bYø  cntP==-1ø  IF cntP=0 THENø    bX=(bX+cX)!cXø    bY=(bY+cY)!cYø    cntP=periodø    ; turn off attact mode, we'reø    ; changing the screen anywayø    ATRACT=0ø  FIø  x1=x RSH 1ø  y1=y RSH 1ø  x0=x1 RSH 1ø  y0=y1 RSH 1ø  IF x0<=y0 THENø    Plot8(127+x0+y0, 127+x1-y1)ø    Plot8(127-x0-y0, 127+x1-y1)ø    Plot8(127+x0-y1, 127-x1)ø    Plot8(127-x0+y1, 127-x1)ø    Plot8(127+x1-y0, 127-y1)ø    Plot8(127-x1+y0, 127-y1)ø  FIøRETURNøø;************************************ø;Erase pointsø;************************************øøPROC GenE()øø  BYTE x=xA+1,ø       y=yA+1øø  xA=(xA+xB)!xBø  yA=(yA+yB)!yBø  cntE==-1ø  IF cntE=0 THENø    xB=(xB+xC)!xCø    yB=(yB+yC)!yCø    cntE=periodø  FIø  x1=x RSH 1ø  y1=y RSH 1ø  x0=x1 RSH 1ø  y0=y1 RSH 1ø  IF x0<=y0 THENø    Erase8(127+x0+y0, 127+x1-y1)ø    Erase8(127-x0-y0, 127+x1-y1)ø    Erase8(127+x0-y1, 127-x1)ø    Erase8(127-x0+y1, 127-x1)ø    Erase8(127+x1-y0, 127-y1)ø    Erase8(127-x1+y0, 127-y1)ø  FIøRETURNøø;************************************ø;Read the parametersø;************************************øøPROC GetParam(STRING param, CARD POINTER cur, initial)øø  CARD resultCøø  STRING numBuf(0)=$550øø  PutE()ø  Print(param)ø  Print(" = ")ø  PrintC(cur^)ø  IF initial THENø    Print(", initial = ")ø    PrintCE(initial^)ø  ELSEø    PutE()ø  FIø  PrintE("ę┼įšę╬ for current value")ø  PrintE("* for initial value")ø  Print("Enter new value 0-65535:  ")ø  resultC=InputC()ø  IF numBuf(0)#0 THENø    IF numBuf(1)='* THENø      IF initial THENø        cur^=initial^ø      FIø    ELSEø      cur^=resultCø    FIø  FIø  IF initial THENø    initial^=cur^ø  FIøRETURNøø;************************************ø;Change the parametersø;************************************øøPROC Params()øø  Graphics(0)ø  PutE()ø  GetParam("aX", @aX, @aXI)ø  GetParam("bX", @bX, @bXI)ø  GetParam("cX", @cX, @cXI)ø  GetParam("aY", @aY, @aYI)ø  GetParam("bY", @bY, @bYI)ø  GetParam("cY", @cY, @cYI)ø  GetParam("Period", @period, 0)ø  GetParam("Persistence", @npts, 0)øRETURNøø;************************************ø;Main procedureø;************************************øøPROC Kal3()øø  BYTE init,trig=$D010,ø       stick=$D300,CH=$2FC,ø       c,søø  CARD iøø  Close(7)ø  Open(7,"K:",4)ø  init=1ø  ;change following for different patternsø  aXI=22175 ; 5221  ; 12767ø  bXI=63751 ; 64449 ; 64471ø  aYI=17791 ; 57669 ; 13183ø  bYI=63791 ; 64489 ; 64511ø  cXI=3ø  cYI=3ø  period=10000ø  npts=2500ø  DOø    IF init THENø      InitGr8()ø      InitP()ø      i=0ø      CH=$FFø      FOR i=1 TO nptsø        DOø        GenP()ø        IF CH#$FF THENø          EXITø        FIø        ODø      init=0ø    FIø    WHILE CH=$FFø      DOø      GenP()ø      GenE()ø      s=stick & $Fø      IF s=7 AND npts<65000 THENø        npts==+1ø        GenP()ø      FIø      IF s=11 AND npts>2 THENø        npts==-1ø        GenE()ø      FIø      WHILE trig=0ø        DOø        ODø      ODø    c=GetD(7) ; get characterø    IF c=' THEN  ; quit if ESC keyø      EXITø    ELSEø      Params()ø      init=1ø    FIø  ODø  Graphics(0)øRETURNøø
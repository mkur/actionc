nir program
global Nop: define [$EA]

routine <program> params=[-] locals=[-]
bb2:
  store @$0491 = $3000
  store @$000E = $3000
  fallthrough

routine Raw params=[-] locals=[-]
  note system-address *
bb0:
  machine items=3 effects=opaque
  fallthrough

routine Main params=[-] locals=[-]
bb1:
  machine items=1 effects=opaque
  call Raw()
  return

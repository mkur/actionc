mir6502 program
global g0 x: byte storage global+0
global g1 y: byte storage global+1

routine r0 Main
b0 bb0:
  store.b global g0+0, #$01
  v0 =.b load global g0+0
  v1 =.b v0 add #$02 carry_in=- carry_out=ignore
  store.b global g1+0, v1
  v2 =.b load global g1+0
  v3 =.b v2 sub #$01 carry_in=- carry_out=ignore
  store.b global g1+0, v3
  return

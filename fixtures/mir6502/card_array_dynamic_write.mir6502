mir6502 program
global g0 words: word storage global+0 size=8 init zero_fill=8 section=global mutable=true
global g1 i: byte storage global+8

routine r0 Main
b0 bb0:
  store.b global g1+0, #$01
  v0 =.w lea global g0+0
  v1 =.b load global g1+0
  store.w computed global_addr g0[v1;2]+0, #$1234
  return

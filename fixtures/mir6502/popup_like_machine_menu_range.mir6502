mir6502 program
global g0 spaces: byte storage global+0
global g1 selected: byte storage global+1
global g2 answer: byte storage global+2
static s0 __nir_str_PopLike_0: Char* bytes [$02 $2B $2A] section=rodata align=1 mutable=false display="+*"
machine m0 items=["First" 'F' "Second" 'S' "Cancel" 'C' $00]

routine r0 menu
b0 bb0:
  machine m0 effects=opaque,stack=?,reads=none,writes=none,clobbers=a|x|y|flags|sp
  unreachable

routine r1 RangeLike
b0 bb1:
  v0 =.w load param p0+0
  v1 =.b load computed v0[#$00;1]+0
  store.b local l1+0, v1
  store.b local l0+0, #$01
  jump b1
b1 bb2:
  v2 =.b load local l0+0
  v3 =.b load local l1+0
  v4 = cmp.b v2 le v3
  branch bool v4 ? b2 : b11
b2 bb3:
  v5 =.w load param p0+0
  v6 =.b load local l0+0
  v7 =.b load computed v5[v6;1]+0
  v8 =.b load param p3+0
  v9 = cmp.b v7 eq v8
  branch bool v9 ? b3 : b6
b3 bb6:
  v10 =.w load param p2+0
  v11 =.b load *v10+0
  v12 = cmp.b v11 ne #$00
  branch bool v12 ? b4 : b5
b4 bb9:
  v13 =.w load param p2+0
  v14 =.b load *v13+0
  v15 =.b v14 sub #$01 carry_in=- carry_out=ignore
  store.b *v13+0, v15
  jump b5
b5 bb8:
  jump b10
b6 bb7:
  v16 =.w load param p0+0
  v17 =.b load local l0+0
  v18 =.b v17 add #$01 carry_in=- carry_out=ignore
  v19 =.b load computed v16[v18;1]+0
  v20 =.b load param p3+0
  v21 = cmp.b v19 eq v20
  branch bool v21 ? b7 : b10
b7 bb10:
  v22 =.w load param p2+0
  v23 =.b load *v22+0
  v24 =.b load param p1+0
  v25 = cmp.b v23 lt v24
  branch bool v25 ? b8 : b9
b8 bb12:
  v26 =.w load param p2+0
  v27 =.b load *v26+0
  v28 =.b v27 add #$01 carry_in=- carry_out=ignore
  store.b *v26+0, v28
  jump b9
b9 bb11:
  jump b10
b10 bb5:
  v29 =.b load local l0+0
  v30 =.b v29 add #$02 carry_in=- carry_out=ignore
  store.b local l0+0, v30
  jump b1
b11 bb4:
  v31 =.b load param p3+0
  store.b fixed_zp $A0, v31
  return

routine r2 MenuKey
b0 bb13:
  v0 =.w load param p0+0
  v2 =.b load *v0+0
  v3 =.w v0 add v2 carry_in=- carry_out=ignore
  v4 =.w v3 add #$03 carry_in=- carry_out=ignore
  store.w param p0+0, v4
  v6 =.b load *v4+0

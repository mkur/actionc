b2 bb32:
  v17 =.b load local l0+0
  v18 = cmp.b v17 eq #$9B
  branch bool v18 ? b3 : b4
b3 bb35:
  v19 =.w load param p0+0
  call r2 args=[v19.w -> a:x] result=v20.b <- return+0 clobbers=a|x|y|flags preserves=- effects=stack=?,reads=none,writes=none,clobbers=a|x|y|flags
  store.b fixed_zp $A0, v20
  return
b4 bb34:
  store.b fixed_zp $A0, #$1B
  return

routine r8 Main
b0 bb36:
  store.b global g1+0, #$00
  v0 =.w routine_addr r0
  v1 =.w v0
  call r7 args=[v1.w -> a:x, #$00.b -> y, #$03.b -> fixed_zp $A3] result=v3.b <- return+0 clobbers=a|x|y|flags preserves=- effects=stack=?,reads=none,writes=none,clobbers=a|x|y|flags

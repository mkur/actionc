routine r7 PopLike
b0 bb31:
  v0 =.w load param p0+0
  store.w local l3+0, v0
  v1 =.b load param p2+0
  store.b global g0+0, v1
  v2 =.w load local l3+0
  call r4 args=[v2.w -> a:x] result=v3.b <- return+0 clobbers=a|x|y|flags preserves=- effects=stack=?,reads=none,writes=none,clobbers=a|x|y|flags
  v4 =.b v3 sub #$01 carry_in=- carry_out=ignore
  store.b local l1+0, v4
  v6 =.w lea param p1+0
  call r1 args=[static_addr s0.w -> a:x, v4.b -> y, v6.w -> fixed_zp $A3:fixed_zp $A4, #$2A.b -> fixed_zp $A5] result=v7.b <- return+0 clobbers=a|x|y|flags preserves=- effects=stack=?,reads=none,writes=none,clobbers=a|x|y|flags
  store.b local l0+0, v7
  v8 =.w load local l3+0
  v9 =.b load local l0+0
  call r6 args=[v8.w -> a:x, v9.b -> y] result=v10.w <- return+0 clobbers=a|x|y|flags preserves=- effects=stack=?,reads=none,writes=none,clobbers=a|x|y|flags
  store.w local l2+0, v10
  v12 = cmp.w v10 ne #$0000
  branch bool v12 ? b1 : b2
b1 bb33:
  v13 =.w load local l2+0
  store.w param p0+0, v13
  v14 =.w load local l3+0
  v15 =.w load param p0+0
  call r5 args=[v14.w -> a:x, v15.w -> y:fixed_zp $A3] result=v16.b <- return+0 clobbers=a|x|y|flags preserves=- effects=stack=?,reads=none,writes=none,clobbers=a|x|y|flags
  store.b param p1+0, v16
  store.b local l0+0, #$9B

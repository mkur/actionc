mir6502 program
global g0 screen: byte storage global+0 size=2 init bytes=[$80 $05] zero_fill=0 section=global mutable=true
global g1 out: byte storage global+2

routine r0 Take
b0 bb0:
  v0 =.w load param p0+0
  v1 =.b load computed v0[#$00;1]+0
  store.b global g1+0, v1
  return

routine r1 Main
b0 bb1:
  call r0 args=[#$0580.w -> a:x] result=- clobbers=a|x|y|flags preserves=- effects=stack=?,reads=none,writes=none,clobbers=a|x|y|flags
  return

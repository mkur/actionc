mir6502 program
global g0 b: byte storage global+0
global g1 w: word storage global+1

routine r0 Main
b0 bb0:
  store.b global g0+0, #$07
  v0 =.b load global g0+0
  v1 =.w extend v0 from.b
  store.w global g1+0, v1
  v2 =.w load global g1+0
  v3 =.b truncate v2 from.w
  store.b global g0+0, v3
  return

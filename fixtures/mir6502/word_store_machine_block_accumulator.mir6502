mir6502 program
machine m0 items=[$A2 $00]
machine m1 items=[$9D $0344 $A5 r+1 $9D $0345]

routine r0 Main
  local l0 init zero_fill=4 section=local mutable=true
b0 bb0:
  machine m0 effects=opaque,stack=?,reads=none,writes=none
  v0 =.w lea local l0+0
  store.w $0086, v0
  machine m1 effects=opaque,stack=?,reads=none,writes=none
  return

mir6502 program
global g0 i: byte storage global+0
global g1 sum: byte storage global+1

routine r0 Main
b0 bb0:
  store.b global g0+0, #$00
  jump b1
b1 bb1:
  v0 =.b load global g0+0
  v1 = cmp.b v0 le #$03
  branch bool v1 ? b2 : b3
b2 bb2:
  v2 =.b load global g0+0
  v3 =.b load global g1+0
  v4 =.b v3 add v2 carry_in=- carry_out=ignore
  store.b global g1+0, v4
  v5 =.b load global g0+0
  v6 =.b v5 add #$01 carry_in=- carry_out=ignore
  store.b global g0+0, v6
  jump b1
b3 bb3:
  return

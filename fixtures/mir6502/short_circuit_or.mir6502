mir6502 program
global g0 a: byte storage global+0
global g1 b: byte storage global+1
global g2 out: byte storage global+2

routine r0 Main
b0 bb0:
  v0 =.b load global g0+0
  v1 = cmp.b v0 ne #$00
  branch bool v1 ? b2 : b1
b1 bb4:
  v2 =.b load global g1+0
  v3 = cmp.b v2 ne #$00
  branch bool v3 ? b2 : b3
b2 bb2:
  store.b global g2+0, #$01
  jump b4
b3 bb3:
  store.b global g2+0, #$02
  jump b4
b4 bb1:
  return

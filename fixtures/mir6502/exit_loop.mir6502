mir6502 program
global g0 x: byte storage global+0

routine r0 Main
b0 bb0:
  jump b1
b1 bb1:
  v0 =.b load global g0+0
  v1 = cmp.b v0 lt #$0A
  branch bool v1 ? b2 : b5
b2 bb2:
  v2 =.b load global g0+0
  v3 = cmp.b v2 eq #$04
  branch bool v3 ? b3 : b4
b3 bb5:
  jump b5
b4 bb4:
  v4 =.b load global g0+0
  v5 =.b v4 add #$01 carry_in=- carry_out=ignore
  store.b global g0+0, v5
  jump b1
b5 bb3:
  return

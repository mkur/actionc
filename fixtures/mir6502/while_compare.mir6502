mir6502 program
global g0 x: byte storage global+0

routine r0 Main
b0 bb0:
  jump b1
b1 bb1:
  v0 =.b load global g0+0
  v1 = cmp.b v0 lt #$03
  branch bool v1 ? b2 : b3
b2 bb2:
  v2 =.b load global g0+0
  v3 =.b v2 add #$01 carry_in=- carry_out=ignore
  store.b global g0+0, v3
  jump b1
b3 bb3:
  return

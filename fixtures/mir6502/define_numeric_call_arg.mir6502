mir6502 program
global g0 CLEAR: define $00 storage global+0

routine r0 Block
b0 bb0:
  return

routine r1 Main
b0 bb1:
  store.b local l0+0, #$04
  store.b local l1+0, #$02
  call r0 args=[#$0000.b -> a, #$04.b -> x, #$02.b -> y] result=- clobbers=a|x|y|flags preserves=- effects=stack=?,reads=none,writes=none,clobbers=a|x|y|flags
  return

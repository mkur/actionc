mir6502 program
global g0 words: word storage global+0 size=8 init zero_fill=8 section=global mutable=true
global g1 out: word storage global+8

routine r0 Take
b0 bb0:
  v0 =.w load param p0+0
  v1 =.w load computed v0[#$01;2]+0
  store.w global g1+0, v1
  return

routine r1 Main
b0 bb1:
  v0 =.w lea global g0+0
  call r0 args=[v0.w -> a:x] result=- clobbers=- preserves=- effects=stack=?,reads=none,writes=none
  return

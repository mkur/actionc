mir6502 program
global g0 data: byte storage global+0 size=4 init zero_fill=4 section=global mutable=true
global g1 out: byte storage global+4

routine r0 Take
b0 bb0:
  v0 =.w load param p0+0
  v1 =.b load computed v0[#$01;1]+0
  store.b global g1+0, v1
  return

routine r1 Main
b0 bb1:
  v0 =.w lea global g0+0
  call r0 args=[v0.w -> a:x] result=- clobbers=- preserves=- effects=stack=?,reads=none,writes=none
  return

mir6502 program
global g0 a: word storage global+0
global g1 out: word storage global+2
global g2 count: byte storage global+4

routine r0 Main
b0 bb0:
  v0 =.w load global g0+0
  v1 =.b load global g2+0
  v2 =.w v0 lsh v1 carry_in=- carry_out=ignore
  store.w global g1+0, v2
  v3 =.w load global g0+0
  v4 =.b load global g2+0
  v5 =.w v3 rsh v4 carry_in=- carry_out=ignore
  store.w global g1+0, v5
  return

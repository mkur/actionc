;                  
;    windows       
;                  

MODULE

 BYTE openwindows
 CHAR ARRAY frame(8)="||"
                         
PROC SavePos()

 CARD adr
  
  adr = Alloc(4)
  MovePage(adr, @zx, 4)
RETURN


PROC RestorePos=*()

  allocp==-4
  MovePage(@zx, allocp, 4)  
RETURN


PROC Window(BYTE x, y, dx, dy)

 CARD buf BYTE h
 
  SavePos()

  openwindows==+1

  zx = x      zy = y
  zdx = dx    zdy = dy

  Relpos(0,0)
 
  buf = Alloc((zdx+1)*(zdy+1))
  Push(buf)
  GetImage(buf, zdx, zdy)
  SavePos()

  Block(CLEAR, zdx, zdy)

  CalcAdr()

  screen^ = frame(0)
  h = 40-zdx
 
  FOR i=2 TO zdx DO
    screen==+1
    screen^=frame(1)
  OD

  screen==+1
  screen^ = frame(2)

  FOR i=2 TO zdy DO
    screen==+h
    screen^ = frame(3)
    screen==+zdx   
    screen^ = frame(4)
  OD

  screen==+h
  screen^ = frame(5)
  screen==+1
  FOR i=2 TO zdx DO
    screen^ = frame(6)
    screen==+1
  OD

  screen^ = frame(7)

  zx==+1  zy==+1
  zdx==-1 zdy==-1

  Relpos(0,0)
RETURN


PROC CloseWindow()
   
 CARD buf

  RestorePos()

  openwindows==-1

  Relpos(0,0)
  buf = Pull()
  Free(buf)
  PutImage(buf, zdx, zdy)
  RestorePos()
RETURN


CHAR FUNC Range(CHAR ARRAY s, BYTE max, BYTE POINTER c)

 BYTE i=$A0,len=$A1,f=$A2
 CHAR ch=$A3

  len=s(0)
  DO
    ch=getchar() f=true
    FOR i=1 TO len STEP 2 DO
      IF s(i)=ch THEN
        IF c^#0 THEN c^==-1 ELSE f=false FI
      ELSEIF s(i+1)=ch THEN
        IF c^<max THEN c^==+1 ELSE f=false FI
      FI
    OD
    UNTIL f
  OD
RETURN(ch)


BYTE FUNC InputLine(CHAR ARRAY string, BYTE maxlen, curpos)

 CHAR ch

  SavePos()
  zx=kx zy=ky
 
  DO
    Relpos(curpos,0)
    Block(INVERT,0,0)
    ch=Getchar()
    Block(INVERT,0,0)
  
    IF ch=126 THEN
      IF curpos#0 THEN
        curpos==-1
        Relpos(curpos,0)
        Putchar(32)
      FI
    ELSEIF ch=156 THEN
      curpos=0
      Relpos(0,0)
      Block(CLEAR,MaxLen-1,0)
    ELSEIF ch=ESC OR ch=EOL THEN EXIT
    ELSEIF curpos<MaxLen THEN
      string(curpos+1)=ch
      Putchar(ch)
      curpos==+1
    FI
  OD
  string(0)=curpos
  RestorePos()
  IF ch=ESC OR curpos=0 THEN RETURN(0) FI
RETURN(1)


MODULE

BYTE spaces


BYTE FUNC Key( BYTE POINTER menu )

  menu ==+ menu^ + 3
RETURN( menu^ )


CARD FUNC Next( BYTE POINTER menu )
RETURN( menu + menu^ + 5 )


BYTE FUNC Ord( BYTE POINTER menu, item )

 BYTE c

  c = 0

  WHILE menu^ DO
    IF menu = item THEN
      EXIT
    FI
    c ==+ 1
    menu = Next( menu )
  OD
RETURN( c )


BYTE FUNC Items(BYTE POINTER menu)
               
 BYTE c

  c = 0

  WHILE menu^ DO
    c ==+ 1
    menu = Next( menu )
  OD
RETURN( c )

                                     
CARD FUNC FindItem( BYTE POINTER menu CHAR ch )

  WHILE menu^ DO
    IF Key( menu ) = ch THEN RETURN( menu ) FI
    menu = Next( menu )
  OD
RETURN( nil )


PROC DrawMenu( BYTE POINTER menu )

  zx = kx
  zy = ky 

  WHILE menu^ DO
    Print( menu )
    kx ==+ spaces
    menu = Next( menu )
  OD
RETURN


CARD FUNC MoveMenuBar( BYTE POINTER menu BYTE c )

 BYTE p, a

  p = 0

  WHILE c DO
    a = menu^ + spaces
    p ==+ a
    c ==- 1
    menu = Next( menu )
  OD

  Relpos( p, 0 )
  Block( INVERT, menu^-1, 0 )

RETURN( menu )


CHAR FUNC PopUp( BYTE POINTER mp BYTE c, spc )

 CHAR ch, value BYTE d, limit CARD menu
 
  Push( menu )
  SavePos()

  menu = mp
  spaces = spc
  limit = Items( menu ) - 1

  DrawMenu( menu )
  mp = MoveMenuBar( menu, c )
          
  DO
    d = c
    ch = Range( "+*", limit, @c )

    IF FindItem( menu, ch ) THEN
      mp = FindItem( menu, ch )
      c = Ord( menu, mp )
      ch = EOL
    FI

    IF c # d THEN
      MoveMenuBar( menu, d )
      mp = MoveMenuBar( menu, c )
    FI   

  UNTIL ch = ESC OR ch = EOL OD

  RestorePos()
  menu = Pull()

  IF ch = EOL THEN
    RETURN( Key( mp ) )
  ELSE
    RETURN( ESC )
  FI


PROC Init()
 
 CARD h
 
  h = 0
  FOR i = 0 TO 23 DO
    quickmul(i) = h
    quickmul(i + 24) = h rsh 8
    h ==+ 40
  OD

  FOR i = 0 TO 8 DO
    frame(i) = Internal(frame(i + 1))
  OD    

  allocp = allocbuf
  openwindows = 0
RETURN


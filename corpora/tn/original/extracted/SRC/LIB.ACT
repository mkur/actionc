;                     
; memory allocation   
;                     

MODULE
  
BYTE ARRAY allocbuf($800)=$2000

PROC MovePage=*(CARD dst, src BYTE len)
[$85 $A0 $86 $A1 $84 $A2 $A4 $A4 $88 $B1 $A2 $91 $A0 $88 $C0 $FF $D0 $F7 $60]


CARD FUNC Alloc(CARD n)

  allocp==+n
RETURN(allocp-n)


PROC Free(CARD adr)

  allocp = adr
RETURN


PROC Push(CARD data)

  allocp^ = data  
  allocp==+2
RETURN


CARD FUNC Pull=*()

  allocp==-2
RETURN(allocp^)


;                     
;    gfx routines     
;                     

MODULE
  
DEFINE  CLEAR="$00",
         FILL="$40",
       INVERT="$80"

BYTE ARRAY quickmul(48)

PROC CalcAdr=*()
[$A6 ky $A5 $58 $18 $7D quickmul    
 $85 scl $A5 $59 $7D quickmul+24
 $85 sch $A5 scl $65 kx $85 scl $90 $02 $E6 sch $60]


PROC Position=*(BYTE x, y)
[$85 kx $86 ky $60]


PROC Relpos=*(BYTE x, y)
[$18 $65 zx $85 kx $8A $65 zy $85 ky $60]


BYTE FUNC Internal=*(CHAR ch)
[
$A8 $2A $2A $2A $2A $29 $03 $AA 
$98 $29 $9F $1D $49 $FB $85 $A0 
$60
]


BYTE FUNC Ascii=*(CHAR ch)
[
$A8 $2A $2A $2A $2A $29 $03 $AA 
$98 $29 $9F $1D $4D $FB $85 $A0 
$60
]


CHAR FUNC Getchar=*()
[$20 $F2F8 $85 $A0 $60]


PROC Putchar(CHAR ch)

  CalcAdr()
  Screen^ = Internal(ch)
  kx==+1
RETURN


PROC Print(CHAR ARRAY s)

  BYTE i

  FOR i=1 TO s(0) DO
    Putchar(s(i))
  OD
RETURN 


PROC PrintE(CHAR ARRAY s)

  Print(s)
  kx=zx ky==+1
RETURN


PROC Block=*(BYTE mode, dx, dy)
[
$48 $86 $A0 $20 CalcAdr $98 $AA
$68 $C9 $80 $F0 $20 $C9 $40 $F0
$04 $A9 $00 $85  r0 $A4 $A0 $A5
 r0 $91 scl $88 $10 $FB $18 $A5
scl $69 $28 $85 scl $90 $02 $E6
sch $CA $10 $E9 $60 $A4 $A0
$B1 scl $49 $80 $91 scl $88
$10 $F7 $18 $A5 scl $69 $28 $85
scl $90 $02 $E6 sch $CA $10 $E7
$60
]


PROC GetImage=*(CARD adr BYTE dx, dy)
[ 
$85 $A0 $86 $A1 $84 $A2 $C8 $84
$A4 $20 CalcAdr $A6 $A3 $A4 $A2 $B1 scl $91 $A0 $88
$10 $F9 $18 $A5 scl $69 $28 $85
scl $90 $03 $E6 sch $18 $A5 $A0
$65 $A4 $85 $A0 $90 $02 $E6 $A1
$CA $10 $DE $60
]


PROC PutImage=*(CARD adr BYTE dx, dy)
[
$85 $A0 $86 $A1 $84 $A2 $C8 $84
$A4 $20 CalcAdr $A6 $A3 $A4 $A2 $B1 $A0 $91 scl $88
$10 $F9 $18 $A5 scl $69 $28 $85
scl $90 $03 $E6 sch $18 $A5 $A0
$65 $A4 $85 $A0 $90 $02 $E6 $A1
$CA $10 $DE $60
]



;ааааааааааааааааааааааааааааааааааааЫ;Ы;PMG.ACT - routines to implement andЫ;manipulate the P/M capabilities ofЫ;the Atari.Ы;Ы;   Copyright (c) 1984 by OSS,Inc.,Ы;      Mark Rose, and Mike FitchЫ;ааааааааааааааааааааааааааааааааааааЫЫMODULEЫЫBYTE PM_Mode=[0],Ы     PMHitClr=$D01EЫЫCARD PM_BaseAdrЫЫBYTE ARRAYЫ      PM_Hpos(8)=$D000,Ы      PMHpos(8)=[0 0 0 0 0 0 0 0],Ы      PMVpos(8)=[0 0 0 0 0 0 0 0],Ы      PM_MisMask(4)=[$FC $F3 $CF $3F],Ы      PM_Width(5)=$D008ЫЫCARD ARRAYЫ      PM_BSize=[0 $100 $80],Ы      PM_Waste=[0 768 384]ЫЫ;************************************Ы;Routine to turn P/Ms on and off.Ы;When allocating memory it works fromЫ;HiMem down.Ы;************************************ЫЫPROC PMGraphics(BYTE mode)ЫЫ  BYTE DMACtl=$22F,   ;P/M enable loc.Ы       Priority=$26F,Ы       GRACtl=$D01D,Ы       PMBase=$D407,Ы       GraphP0=$D00DЫЫ  CARD HiMem=$2E5,Ы       OldHimem,Ы       AppMHi=$EЫЫ  CARD ARRAY PM_AdrMask=[0 $F800 $FC00],Ы             PM_MemSize=[0 $800 $400]ЫЫ  ; insure that mode is valid-- ignoreЫ  ;   graphics request otherwise.Ы  IF mode > 2 THENЫ    mode = 0Ы  FIЫЫ  Zero(PM_Hpos,8)  ; move them off the screenЫ  Zero(PMHpos,8)Ы  Zero(PMVpos,8)Ы  Zero(PM_Width,5)Ы  Zero(GraphP0,5)Ы  IF PM_Mode#0 THENЫ    Himem=OldHiMemЫ    DMACtl=$22Ы    GRACtl=0Ы  FIЫ  IF mode=0 THEN   ; turn off pmgЫ    DMACtl=$22Ы    GRACtl=0Ы  ELSEЫ    IF mode=1 THEN ;sgl lineЫ      DMACtl=$3EЫ    ELSE           ;dbl lineЫ      DMACtl=$2EЫ    FIЫ    OldHiMem=HiMemЫ    PM_BaseAdr=(HiMem-PM_MemSize(mode)-$80)&PM_AdrMask(mode)Ы    PMBase=PM_BaseAdr RSH 8Ы    IF PM_BaseAdr<AppMHi THENЫ      DMACtl=$22Ы      GRACtl=0Ы      RETURNЫ    FIЫ    HiMem=PM_BaseAdr+PM_Waste(mode)Ы    Priority==&$C0%1Ы    GRACtl=3Ы  FIЫ  PM_Mode=mode   ; save modeЫRETURNЫЫ;************************************Ы;Set the color of a P/MЫ;************************************ЫЫPROC PMColor(BYTE n,hue,lum)ЫЫ  BYTE ARRAY PM_Color(4)=$2C0ЫЫ  n==&3Ы  PM_Color(n)=(hue LSH 4) % (lum & $0F)ЫRETURNЫЫ;************************************Ы;Get the address of a P/M's memoryЫ;blockЫ;************************************ЫЫCARD FUNC PMAdr(BYTE n)ЫЫ  n==&7Ы  IF n>=4 THENЫ    n=0Ы  ELSEЫ    n==+1Ы  FIЫRETURN(PM_BaseAdr+PM_Waste(PM_Mode)+(n*PM_BSize(PM_Mode)))ЫЫ;************************************Ы;Zero out a P/M's memory blockЫ;************************************ЫЫPROC PMClear(BYTE n)ЫЫ  CARD ctrЫЫ  BYTE ARRAY PlayAdrЫЫ  n==&7Ы  playAdr=PMAdr(n)Ы  IF n<4 THENЫ    Zero(PlayAdr,PM_BSize(PM_Mode))Ы  ELSEЫ    n==-4Ы    FOR ctr=0 TO PM_BSize(PM_Mode)-1Ы      DOЫ      PlayAdr(ctr)==&PM_MisMask(n)Ы      ODЫ  FIЫRETURNЫЫ;************************************Ы;Move a P/M to an absolute (x,y) po-Ы;sitionЫ;************************************ЫЫPROC PMMove(BYTE n,x,y);ЫЫ  CARD iЫЫ  BYTE yOffset,Ы       plLength,Ы       mask1,mask2ЫЫ  INT deltaYЫЫ  BYTE ARRAY temp(256),PlPtrЫЫ  IF PM_Mode=0 THENЫ    RETURNЫ  FIЫ  n==&7Ы  deltaY = yЫ  deltaY = deltaY-PMVpos(n)Ы  IF deltaY=0 THENЫ    PM_Hpos(n)=xЫ    PMHpos(n)=xЫ    RETURNЫ  FIЫ  plPtr=PMAdr(n)Ы  plLength=PM_BSize(PM_Mode)Ы  IF deltaY>=0 THENЫ    yOffset=deltaYЫ  ELSEЫ    yOffset=plLength+deltaYЫ  FIЫ  IF n<4 THENЫ    mask1=255Ы    mask2=0Ы  ELSEЫ    mask2=PM_MisMask(n&3)Ы    mask1=mask2!$FFЫ  FIЫЫ;╘шщґаЁщхухаяцауяфхаісґаҐхЁьсухфатїаЄшхаЫ;цяььяіщючауяфхатьяуыаЄяащюуҐхсґхаґЁххфоЫ;Ы; FOR i=0 to plLength-1Ы;  DOЫ;   temp(i)=plPtr(i)&mask1Ы;  ODЫЫ[ $A0 0        ; LDY #0Ы  $AD PlPtr    ; LDA PLPTRЫ  $85 $A0      ; STA $A0Ы  $AD PlPtr+1  ; LDA PLPTR+1Ы  $85 $A1      ; STA $A1Ы;LOOPЫ  $B1 $A0      ; LDA ($A0),YЫ  $2D mask1    ; AND MASK1Ы  $99 temp     ; STA TEMP,YЫ  $C8          ; INYЫ  $CC plLength ; CPY PLLENGTHЫ  $D0 $F2      ; BNE LOOPЫ]ЫЫ;╘шщґаЁщхухаяцауяфхаісґаҐхЁьсухфатїаЄшхаЫ;цяььяіщючауяфхатьяуыаЄяащюуҐхсґхаґЁххфоЫ;Ы; FOR i=0 to plLength-1Ы;  DOЫ;   plPtr(yOffset)==&mask2 %temp(i)Ы;   yOffset==+1Ы;   IF yOffset>=plLength THENЫ;     yOffset=0Ы;   FIЫ;  ODЫЫ[ $A2 0        ; LDX #0Ы  $AC yOffset  ; LDY YOFFSETЫ  $AD PlPtr    ; LDA PLPTRЫ  $85 $A0      ; STA $A0Ы  $AD PlPtr+1  ; LDA PLPTR+1Ы  $85 $A1      ; STA $A1Ы;LOOPЫ  $B1 $A0      ; LDA ($A0),YЫ  $2D mask2    ; AND MASK2Ы  $1D temp     ; ORA TEMP,XЫ  $91 $A0      ; STA ($A0),YЫ  $C8          ; INYЫ  $CC plLength ; CPY PLLENGTHЫ  $D0 2        ; BNE ISLOWЫ  $A0 0        ; LDY #0Ы;ISLOWЫ  $E8          ; INXЫ  $EC plLength ; CPX PLLENGTHЫ  $D0 $E8      ; BNE LOOPЫ]ЫЫ  PMVpos(n)=yЫ  PM_Hpos(n)=xЫ  PMHpos(n)=xЫRETURNЫЫ;************************************Ы;Create a P/MЫ;************************************ЫЫPROC PMCreate(BYTE n  BYTE ARRAY pm BYTE len,width,x,y)ЫЫ  BYTE i,mask,temp,ntemp,Ы       oldwidth=[0]ЫЫ  BYTE ARRAY plPtr,Ы             miswidth=[0 1 0 3]ЫЫ  n==&7Ы  IF n<4 THENЫ    mask=0Ы  ELSEЫ    ntemp=n&3Ы    mask=PM_MisMask(ntemp)Ы  FIЫ  plPtr=PMAdr(n)Ы  FOR i=0 to len-1Ы   DOЫ    plPtr(i+y)==&mask%pm(i)Ы   ODЫ  width==-1Ы  IF n<4 THENЫ    PM_Width(n)=widthЫ  ELSEЫ    temp=(miswidth(width) LSH (ntemp LSH 1))Ы    oldwidth==&mask%tempЫ    PM_Width(4)=oldwidthЫ  FIЫ  PM_Hpos(n)=xЫ  PMHpos(n)=xЫ  PMVpos(n)=yЫRETURNЫЫ;************************************Ы;Test for P/M collisionЫ;************************************ЫЫBYTE FUNC PMHit(BYTE n,cnum)ЫЫ  BYTE ARRAY pmtopf(8)=$D000,Ы             pmtop(8)=$D008ЫЫ  n==&7Ы  IF n<4 THENЫ    n==+4Ы  ELSEЫ    n==-4Ы  FIЫ  IF cnum<4 THENЫ    RETURN ((pmtop(n) RSH cnum) & 1)Ы  ELSEЫ    cnum==&3Ы    RETURN ((pmtopf(n) RSH cnum) & 1)Ы  FIЫRETURN (0)ЫЫ;************************************Ы;Replace Library Graphics routine soЫ;that P/Ms are reset when bitmap modesЫ;are changed.Ы;************************************ЫЫPROC Graphics(BYTE mode)Ы  PMGraphics(0)Ы  Close(6)Ы  Open(6,"S:",(mode&$F0)!$1C,mode)ЫRETURNЫЫ;а┼юфаяца╨═╟о┴├╘аЫЫMODULEЫЫ
;ааааааааааааааааааааааааааааааааааааЫЫ;SORT.ACT - a group of sorting routinesЫ;which allow you to sort BYTE, CARD,Ы;INT, or string data.  The algorithmЫ;used is called a quicksort, and isЫ;very fast (order N ln N) on unsortedЫ;data but is almost as slow as bubbleЫ;or shell sort on presorted dataЫ;(worst case order N^2).ЫЫ;   Copyright (c) 1984 by OSS,Inc.,Ы;      Mark Rose, and Mike FitchЫ;ааааааааааааааааааааааааааааааааааааЫЫMODULEЫЫ; Despite what your Toolkit manual says,Ы; the definition of SortMax is ignoredЫ; by the sort routines does not needЫ; to be changed to match your data size.Ы; (This is due to an improvement in theЫ; way the sort routines work)ЫDEFINE SortMax="10000" ;change value to suit yourselfЫЫCARD ListSizeЫЫBYTE ARRAY BArrayЫЫINT ARRAY IArrayЫЫCARD ARRAY CArray,Ы           List(64) ; big enough for 64K sort elementsЫЫ;************************************Ы;BYTE ComparisionsЫ;************************************ЫЫBYTE FUNC BDescend(CARD i,j)ЫЫ  IF BArray(i)>BArray(j) THENЫ    RETURN (1)Ы  FIЫRETURN (0)ЫЫ;************************************ЫЫBYTE FUNC BAscend(CARD i,j)ЫЫ  IF BArray(i)<BArray(j) THENЫ    RETURN (1)Ы  FIЫRETURN (0)ЫЫ;************************************Ы;CARD ComparisionsЫ;************************************ЫЫBYTE FUNC CDescend(CARD i,j)ЫЫ  IF CArray(i)>CArray(j) THENЫ    RETURN (1)Ы  FIЫRETURN (0)ЫЫ;************************************ЫЫBYTE FUNC CAscend(CARD i,j)ЫЫ  IF CArray(i)<CArray(j) THENЫ    RETURN (1)Ы  FIЫRETURN (0)ЫЫ;************************************Ы;INT ComparisionsЫ;************************************ЫЫBYTE FUNC IDescend(CARD i,j)ЫЫ  IF IArray(i)>IArray(j) THENЫ    RETURN (1)Ы  FIЫRETURN (0)ЫЫ;************************************ЫЫBYTE FUNC IAscend(CARD i,j)ЫЫ  IF IArray(i)<IArray(j) THENЫ    RETURN (1)Ы  FIЫRETURN (0)ЫЫ;************************************Ы;String ComparisonsЫ;************************************ЫЫBYTE FUNC SDescend(CARD i,j)ЫЫ  IF SCompare(CArray(i),CArray(j))>0 THENЫ    RETURN (1)Ы  FIЫRETURN (0)ЫЫ;************************************ЫЫBYTE FUNC SAscend(CARD i,j)ЫЫ  IF SCompare(CArray(i),CArray(j))<0 THENЫ    RETURN (1)Ы  FIЫRETURN (0)ЫЫ;************************************Ы;Interchange 2 BYTE sort elementsЫ;************************************ЫЫPROC BSwap(CARD i,j)ЫЫ  BYTE tempЫЫ  temp=BArray(i)Ы  BArray(i)=BArray(j)Ы  BArray(j)=tempЫRETURNЫЫ;************************************Ы;Interchange 2 sort elements of CARDЫ;or string typesЫ;************************************ЫЫPROC CSwap(CARD i,j)ЫЫ  CARD tempЫЫ  temp=CArray(i)Ы  CArray(i)=CArray(j)Ы  CArray(j)=tempЫRETURNЫЫ;************************************Ы;Interchange 2 INT sort elementsЫ;************************************ЫЫPROC ISwap(CARD i,j)ЫЫ  INT tempЫЫ  temp=IArray(i)Ы  IArray(i)=IArray(j)Ы  IArray(j)=tempЫRETURNЫЫ;************************************Ы;The following two routines are setЫ;to one of the compare and swap routinesЫ;above, depending on the type of dataЫ;being sorted and the order of the sort.Ы;************************************ЫЫBYTE FUNC Compare(CARD i,j)ЫЫPROC Swap(CARD i,j)ЫЫ;************************************Ы;Add a partition to the listЫ;************************************ЫЫPROC AddList(CARD low,high)ЫЫ  IF high+1>low+1 THENЫ    List(ListSize)=lowЫ    ListSize==+1Ы    List(ListSize)=highЫ    ListSize==+1Ы  FIЫRETURNЫЫ;************************************Ы;Retrieve last low,high pair from listЫ;of partitionsЫ;************************************ЫЫPROC GetFirst(CARD POINTER lowP,highP)ЫЫ  ListSize==-1Ы  highP^=List(ListSize)Ы  ListSize==-1Ы  lowP^=List(ListSize)ЫRETURNЫ  Ы;************************************Ы;Divide sort array into partitionsЫ;************************************ЫЫCARD FUNC Partition(CARD low,high)ЫЫ  CARD i,j,pivot,midЫЫ  ; Find median of 1st,middle,and lastЫ  ; elements to use as pivot for partitioning.Ы  mid=(low+high) RSH 1Ы  IF Compare(mid,low) THENЫ    Swap(low,mid)Ы  FIЫ  IF Compare(high,low) THENЫ    Swap(low,high)Ы  FIЫ  IF Compare(mid,high) THENЫ    Swap(mid,high)Ы  FIЫ  pivot=highЫ  i=lowЫ  j=highЫ  WHILE i<jЫ    DOЫ    WHILE Compare(i,pivot)Ы      DOЫ      i==+1Ы      ODЫ    WHILE (Compare(j,pivot)=0) AND (j>i)Ы      DOЫ      j==-1Ы      ODЫ    IF i<j THENЫ      Swap(i,j)Ы    FIЫ    ODЫ  Swap(i,high)ЫRETURN (i)ЫЫ;************************************Ы;Sort using the QuickSort algorithmЫ;************************************ЫЫPROC QuickSort(CARD len)ЫЫ  CARD low,middle,high,iЫЫ  ListSize=0Ы  AddList(0,len-1)Ы  WHILE ListSize>0Ы    DOЫ    GetFirst(@low,@high)Ы    middle=Partition(low,high)Ы    ; Put larger partition onto stack firstЫ    ; in order to decrease maximum stack size.Ы    IF (middle-low) > (high-middle) THENЫ      AddList(low,middle-1)Ы      AddList(middle+1,high)Ы    ELSEЫ      AddList(middle+1,high)Ы      AddList(low,middle-1)Ы    FIЫ    ODЫRETURNЫЫ;************************************Ы;Sort a BYTE ARRAYЫ;************************************ЫЫPROC SortB(BYTE ARRAY data CARD len BYTE order)ЫЫ  IF order THENЫ    Compare=BDescendЫ  ELSEЫ    Compare=BAscendЫ  FIЫ  Swap=BSwapЫ  BArray=dataЫ  QuickSort(len)ЫRETURNЫЫ;************************************Ы;Sort a CARD ARRAYЫ;************************************ЫЫPROC SortC(CARD ARRAY data CARD len BYTE order)ЫЫ  IF order THENЫ    Compare=CDescendЫ  ELSEЫ    Compare=CAscendЫ  FIЫ  Swap=CSwapЫ  CArray=dataЫ  QuickSort(len)ЫRETURNЫЫ;************************************Ы;Sort an INT ARRAYЫ;************************************ЫЫPROC SortI(INT ARRAY data CARD len BYTE order)ЫЫ  IF order THENЫ    Compare=IDescendЫ  ELSEЫ    Compare=IAscendЫ  FIЫ  Swap=ISwapЫ  IArray=dataЫ  QuickSort(len)ЫRETURNЫЫ;************************************Ы;Sort a CARD ARRAY whose elements areЫ;the addresses of stringsЫ;************************************ЫЫPROC SortS(CARD ARRAY data CARD len BYTE order)ЫЫ  IF order THENЫ    Compare=SDescendЫ  ELSEЫ    Compare=SAscendЫ  FIЫ  Swap=CSwapЫ  CArray=dataЫ  QuickSort(len)ЫRETURNЫЫMODULEЫЫ;а┼юфаяца╙╧╥╘о┴├╘аЫЫ
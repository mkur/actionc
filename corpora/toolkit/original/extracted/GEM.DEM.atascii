; GEM by Joel Gluckø; 4 players, joysticksø; Copyright (c) 1984 OSS,Inc. and Joel GluckøøDEFINE max="255"  ; max robotsøøBYTE rb=[1], bl=[0], ms=[70],     ø     wa=[135], ex=[72], gm=[204],ø     nm=[77],ø     gemtaken, numbots, winner,ø     winning=[0],ø     playto=[10], ;winning scoreø     maxbots=[5] ;max robots at end øøINT ARRAY xd(max), yd(max),ø          bxd(max), byd(max)øøCARD ARRAY linept(24)øøBYTE ARRAY alive(max), ø           expl(max),ø           fire(max),ø           image(max),ø           havegem(4),ø           charset(2048),ø           x(max), y(max),ø           bx(max), by(max),ø           score(4)=[0 0 0 0], ø           xst(4)=[1 18 1 18],ø           yst(4)=[1 1 22 22],ø           xsc(4)=[1 17 1 17],ø           ysc(4)=[0 0 23 23]øøCARD csetøøPROC reset()ø   BYTE iøø   FOR i=0 TO 3ø   DO score(i)=0 ODøøRETURNøøPROC pauz(CARD p)ø   CARD loopøø   FOR loop = 0 TO pø   DOø   ;ø   ODøøRETURNøøINT FUNC sign(INT n)ø   ø   IF n<0ø   THEN RETURN(-1)ø   ELSEIF n>0ø       THEN RETURN(1)ø       ELSE RETURN(0)ø   FIøø     øPROC gr1init()ø   CARD scrn, lineø  ø   Graphics(1+16)ø   scrn = Peek(88) ø   scrn ==+ Peek(89) * 256ø   FOR line = 0 TO 23ø   DOø   linept(line) = scrn + (20 * line)ø   ODøøRETURNøøPROC charpats()ø   BYTE i,bø   BYTE ARRAY foo(104)= ø   [0 0 0 0 0 0 0 0 øø    126 129 165 129 165 189 129 126ø    195 195 129 165 129 189 231 60ø    195 36 126 219 126 36 36 231ø    255 219 90 126 60 82 66 126ø    60 60 24 255 153 60 102 102øø    0 0 0 16 56 16 0 0øø    255 170 255 85 255 170 255 85øø    145 137 51 170 101 138 209 68ø    17 128 48 10 97 138 144 68ø    17 128 32 8 1 144 0 68ø    1 32 0 0 0 0 1 64ø    ø    0 56 124 254 254 124 56 16]øø    FOR i = 0 TO 103ø    DOø    Poke(cset+i,foo(i))ø    ODøø    FOR i = 0 TO 80ø    DOø    b = Peek(57344+i+128) ø    Poke(cset+i+104,b)ø    ODøøRETURNø                        øPROC scrninit()ø   CARD iø   ø   gr1init()øø   FOR i=0 TO 4ø   DO Setcolor(i,0,0) ODøø   cset = (charset + 1023) & $FC00øø   FOR i = 0 TO 1023 ø   DO Poke(cset+i,0) ODøø   Poke(756,cset/256)øø   charpats()øø   Setcolor(0,13,8)ø   Setcolor(1,0,15)ø   Setcolor(2,6,4)ø   Setcolor(3,9,6)øøRETURNøø øPROC plot1(BYTE x,y,col)øø   BYTE POINTER pixeløø   pixel = linept(y) + xøø   pixel^ = coløøRETURNøøBYTE FUNC locate1(BYTE x,y)øø   BYTE POINTER pixeløø   pixel = (linept(y) + x)øøRETURN(pixel^)øøPROC newdir(BYTE r)ø   ø   DOø   xd(r)=Rand(3) + -1øø   yd(r)=Rand(3) + -1ø   UNTIL xd(r)<>0 OR yd(r)<>0ø   ODø øRETURNøøPROC walls()ø   BYTE i,x,yøø   FOR i = 0 TO 19ø   DOø   plot1(i,0,wa) plot1(i,23,wa)ø   ODøø   FOR i = 0 TO 23ø   DOø   plot1(0,i,wa) plot1(19,i,wa)ø   ODøø   FOR i = 0 TO 30ø   DOø   x = Rand(10)+5ø   y = Rand(12)+6 ø   plot1(x,y,wa)ø   ODø   ø   FOR i=0 TO 3ø   DOø   plot1(2,i,wa) plot1(17,23-i,wa)ø   plot1(i,21,wa) plot1(19-i,2,wa)ø   ODø  øRETURNøøPROC initsnd()ø   Poke($D20F,3) ; Damn OS Bug!ø   Poke($D208,0) ; cost me 5 minutes!øRETURNøøøPROC plotgem()ø   plot1(9,11,gm)ø   gemtaken=0øRETURNø   øPROC rinit()ø   BYTE pix,rø ø   walls()ø   plotgem()ø   initsnd()øø   FOR r = 0 TO numbots-1ø   DOø      ø      IF r<4ø      THEN x(r)=xst(r) y(r)=yst(r)ø      ELSE DO ø           x(r)=Rand(10)+5 y(r)=Rand(12)+6ø           pix = locate1(x(r),y(r))ø           ø              IF pix = bl OR pix=4+rbø              THEN EXIT ø              FIøø           ODø      FIøø   alive(r)=1  ø   IF r<4 THEN image(r)=r+rbø               havegem(r)=0ø          ELSE image(r)=4+rbø   FIø   expl(r)=0 fire(r)=0ø   bx(r)=0 by(r)=0ø   plot1(x(r),y(r),image(r))ø   newdir(r)ø   ODøøRETURNøøPROC scores()ø   BYTE iøø   winning = 0øø   FOR i = 0 TO 3ø   DOø      IF score(i)>9ø      THEN plot1(xsc(i),ysc(i),score(i)/10+nm)ø      FIø      ø      plot1(xsc(i)+1,ysc(i),(score(i) MOD 10)+nm)ø      ø      IF score(i)>score(winning)ø      THEN winning=iø      FI   ø   ODøøRETURNøøPROC regen(BYTE r)ø   BYTE pixøø      IF r=0 THEN x(r)=1 y(r)=1ø      ELSEIF r=1 THEN x(r)=18 y(r)=1ø      ELSEIF r=2 THEN x(r)=1 y(r)=22ø      ELSEIF r=3 THEN x(r)=18 y(r)=22ø      ELSE x(r)=Rand(14)+3 y(r)=Rand(18)+3ø      FIøø      pix = locate1(x(r),y(r))ø      IF pix = bl ø      THEN alive(r)=1 ø           plot1(x(r),y(r),image(r))ø      FI     øøRETURNø   øBYTE FUNC ahead(BYTE a,b INT ad,bd)ø   BYTE pixø   pix = locate1(a+ad,b+bd)ø   ø   IF pix=bl OR (pix>=ex AND pix<=ex+4)ø   THEN RETURN(0)  ;blankø   ELSEIF pix=wa OR (pix>=nm AND pix<=nm+9)ø   THEN RETURN(2)  ;wall or scoreø   ELSEIF (pix>=rb AND pix<=rb+4)ø          OR (pix>=rb+192 AND pix<=rb+196) ø   THEN RETURN(1)  ;robotø   ELSEIF pix=msø   THEN RETURN(3)  ;missileø   ELSEIF pix=gmø   THEN RETURN(4)  ;gemø   FIøøPrintF("%ECollision error: AHEAD%E")øBreak()øøRETURN(0) ;dummyøøPROC getdir(BYTE r)ø   BYTE ARRAY sdir(31)=ø        [1 1 1 1 1 1 1 1ø         1 1 2 2 2 0 2 1ø         1 1 0 2 0 0 0 1ø         1 1 1 2 1 0 1 1]ø   BYTE stkøø   stk = Stick(r)ø   ø   xd(r) = sdir(stk*2) + -1ø   yd(r) = sdir((stk*2)+1) + -1øøRETURNøøPROC explode(BYTE r)ø     CARD pixøø     IF expl(r)>1 ø     THEN plot1(x(r),y(r),(5-expl(r))+ex)ø          Sound(0,100,8,expl(r)*3)ø     ELSE plot1(x(r),y(r),bl)ø          Sound(0,0,0,0)ø     FIø     ø     expl(r) ==- 1øøRETURNøøPROC cease_fire(BYTE r)øø   IF locate1(bx(r),by(r))=msø   THEN plot1(bx(r),by(r),bl)ø   FIøø   fire(r)=0ø   Sound(1,0,0,0)øøRETURNø   øPROC kill(BYTE r) øø   alive(r) = 0 ; DEADø   expl(r) = 5ø   explode(r)ø   cease_fire(r)øø   IF r<4ø   THEN IF havegem(r)=1ø        THEN plotgem()ø             havegem(r)=0ø             Sound(2,0,0,0)ø             Sound(3,0,0,0)ø        FIø   FIøøRETURNøøBYTE FUNC findr(BYTE a,b)  ;find robotø   BYTE iøø   FOR i = 0 TO numbots-1ø   DOø      IF x(i)=a AND y(i)=b AND alive(i)=1ø      THEN RETURN(i)ø      FIø   ODøø   PrintF("%EError: findr x=%U y=%U%E", a, b)ø   Break()øRETURN(0);øøPROC getgem(BYTE r)øø     havegem(r)=1øø     plot1(9,11,bl)øøRETURNøøPROC qwin(BYTE r)ø    ø     IF x(r)=xst(r) AND y(r)=yst(r)ø     THEN winner=r+1ø     FIøøRETURNøøPROC drawbot(BYTE r)øø   IF r>3ø   THEN plot1(x(r),y(r),image(r))ø   ELSEIF havegem(r)=1ø   THEN plot1(x(r),y(r),image(r)+192)ø        qwin(r)ø   ELSE plot1(x(r),y(r),image(r))ø   FIøøRETURNøøPROC move(BYTE r)ø   BYTE targ,a,b,pixøø   IF r<4 ø   THEN getdir(r) ø        IF Strig(r)=0 ø        THEN IF fire(r)=0ø             THEN fire(r)=1ø             FIø             RETURNø        FIø   ELSEIF Rand(0)<32 THEN newdir(r) ø          IF gemtaken=1 AND fire(r)=0ø          THEN fire(r)=1ø          FIø   FIøø   IF xd(r)=0 AND yd(r)=0ø   THEN drawbot(r)ø        RETURNø   FIøø   pix=ahead(x(r),y(r),xd(r),yd(r))ø   IF pix=1ø   THEN kill(r)ø        a=x(r)+xd(r) b=y(r)+yd(r) ø        targ = findr(a,b)ø        kill(targ)ø        RETURNø   ELSEIF pix=2 OR (pix=4 AND r>3)ø   THEN IF r>3 ø        THEN newdir(r) ø        FIø        RETURNø   ELSEIF pix=3ø   THEN kill(r)ø        RETURNø   ELSEIF pix=4 AND r<4ø   THEN gemtaken=1ø        getgem(r)ø   FIøø   plot1(x(r),y(r),bl)ø   x(r) ==+ xd(r)ø   y(r) ==+ yd(r)ø   drawbot(r)øøRETURNøøøPROC initfire(BYTE r)ø   BYTE targ,pixøø   IF xd(r)=0 AND yd(r)=0ø   THEN fire(r)=0 RETURNø   FIøø   bx(r)=x(r) by(r)=y(r)ø   bxd(r)=xd(r) byd(r)=yd(r)øø   pix=ahead(bx(r),by(r),bxd(r),byd(r))ø   IF pix=1ø   THEN targ = findr(bx(r)+bxd(r),by(r)+byd(r))ø        kill(targ)ø        cease_fire(r)ø        RETURNø   ELSEIF pix=2 OR pix=4ø   THEN cease_fire(r) RETURNø   FIøø   bx(r) ==+ bxd(r)ø   by(r) ==+ byd(r)ø   plot1(bx(r),by(r),ms)ø   Sound(1,0,8,8)ø   fire(r)=2øøRETURNø   øPROC bullet(BYTE r)ø   BYTE targ,pixøø   IF fire(r)=1ø   THEN initfire(r) RETURNø   FIøø   pix=ahead(bx(r),by(r),bxd(r),byd(r))ø   IF pix=1ø   THEN targ = findr(bx(r)+bxd(r),by(r)+byd(r))ø        kill(targ)ø        cease_fire(r)ø        RETURNø   ELSEIF pix=2 OR pix=4ø   THEN cease_fire(r) RETURNø   FIø   ø   ; move it:ø   plot1(bx(r),by(r),bl)ø   bx(r) ==+ bxd(r)ø   by(r) ==+ byd(r)ø   plot1(bx(r),by(r),ms)ø   Sound(1,fire(r)*2,8,8)ø   fire(r) ==+ 1øøRETURNøøPROC action(BYTE r)  ø   ø   IF alive(r)ø   THEN move(r)ø   ELSEIF expl(r)>0 ø   THEN explode(r)ø   ELSE IF r<4 OR gemtaken=1 ø        THEN regen(r)ø        FIø   FIøøRETURNøøPROC shots()ø   BYTE røø   FOR r= 0 TO numbots-1ø   DOø   IF fire(r) THEN bullet(r)ø   FIø   ODøøRETURNøøPROC reward(BYTE r)ø   score(r) ==+ 1øRETURNøøPROC tick()ø   BYTE cøø   c=Peek(20)øø   DOø   UNTIL c<>Peek(20)ø   ODøøRETURNøøPROC round(CARD num)ø   BYTE r,c,count=[0],count2=[0],vol=[0]ø   CARD speedøø   numbots=numøø   IF 800-(numbots*40)<0ø   THEN speed=0ø   ELSE speed=800-(numbots*40)ø   FIøø   scrninit()ø   rinit()ø   scores()ø   Poke(764,255) Poke(77,0)ø   winner=0ø   DOø      FOR r = 0 TO numbots-1ø      DOø      action(r)øø      count ==+ 1ø      IF count = (numbots RSH 1)-1 ø      THEN count = 0 shots() ø      FIøø      IF gemtaken=0 ø      THEN plotgem()ø      ELSE Sound(2,50,10,15-vol)ø           vol=(vol+1) & 15ø      FI øø      count2 ==+ 1ø      IF count2 = (numbots RSH 1)ø      THEN count2=0 tick() tick()ø      FIøø      ODøø   c=Peek(20) Poke(711,c)ø   UNTIL winner>0 ø   ODø  ø   Sndrst()øø   reward(winner-1)øøRETURNøøPROC intro()øø   Graphics(0)øø   PrintF("%E%EWelcome to GEM, by Joel Gluck.%E%E")øø   DOø   PrintF("%EHow many points wins? ")ø   playto = InputB()ø   UNTIL playto>0ø   ODøø   PrintF("%E%EHow many robots in final round? ")ø   maxbots = InputB()øø   PrintF("%E%EPress START to begin...")øø   DOø   UNTIL Peek(53279)=6ø   ODøøRETURNøøBYTE FUNC playagain()ø   BYTE køø   Graphics(0)ø   PrintF("%E%EGame over!%E")ø   DOø      PrintF("%EPlay again (y/n)? ")ø      k=GetD(1)ø      IF k='y OR k='Y THEN RETURN(1)ø      ELSEIF k='n OR k='N THEN RETURN(0)ø      FIø   ODøøøPROC plotim(BYTE r)ø   BYTE x,y,pix,vol,pø   BYTE ARRAY mask(8) = [128 64 32 16ø                           8  4  2  1]ø   ø   FOR x=0 TO 7ø   DOø      FOR y=0 TO 7ø      DOø         pix = mask(x) & ø               Peek(cset+((r+1)*8)+y)ø         IF pix<>0ø         THEN plot1(x*2+2,y*2+4,image(r))ø              plot1(x*2+3,y*2+4,image(r))ø              plot1(x*2+2,y*2+5,image(r))ø              plot1(x*2+3,y*2+5,image(r))ø         FIø      ODø   OD    øø   FOR vol = 0 TO 15ø   DOø      Sound(0,50,10,15-vol)ø      Sound(1,100,10,15-vol)ø      Sound(2,150,10,15-vol)ø      Sound(3,200,10,15-vol)ø      Setcolor(0,vol/2+2,10)ø         FOR p = 1 TO 8ø         DO tick() ODø   ODøø   FOR p = 1 TO 90ø   DOø   tick()ø   ODøøRETURNøøøøPROC announce(BYTE r)ø   BYTE i,nø   INT xd,yd,xx,yyø   ø   scores()ø ø   FOR i = 0 TO 15ø   DOø      FOR n=0 TO 100ø      DOø      Sound(0,n,8,15-i)ø      Setcolor(2,6,n/10)ø      ODø   tick()ø   ODø   ø   Setcolor(2,0,0) Setcolor(3,9,6)ø ø   FOR i=0 TO 11ø   DOø      Sound(0,11-i,8,15)ø      Sound(1,24-(i*2),10,8)ø      Setcolor(0,i,12)ø      FOR n=0 TO numbots-1ø      DOø         IF alive(n)=1 AND n<>rø         THEN xx=x(n)ø              yy=y(n)ø              xd=sign(9-xx) ø              yd=sign(11-yy)ø              plot1(x(n),y(n),bl)ø              x(n)=x(n)+xdø              y(n)=y(n)+ydø              plot1(x(n),y(n),image(n))ø         FIø      ø      ODø      tick() tick()ø   ODøøSndrst() plot1(9,11,bl)øøplotim(r)ø  øRETURNøøPROC rdmize()ø   BYTE a,b,i,jøø   FOR a=0 TO 16ø   DOø      FOR b=0 TO 6ø      DOø      bx(b+a*7) = aø      by(b+a*7) = bø      ODø   ODøø   FOR i=0 TO 118ø   DOø      j=Rand(119)ø      a=bx(i)  b=by(i)ø      bx(i)=bx(j)  by(i)=by(j)ø      bx(j)=a  by(j)=bø   ODøøRETURNøøPROC gwarp(BYTE x,y)ø   BYTE g,h,f,freqø   CARD a,b,loopøø   DOø   a=Rand(3)-1  b=Rand(3)-1ø   UNTIL a<>0 OR b<>0ø   ODøø   g = locate1(x,y)ø   f = 0  freq = 0øø   DOø      h = locate1(x+a,y+b)ø      plot1(x,y,f) f=hø      x ==+ a  y ==+ bø      plot1(x,y,g)ø      freq ==+ 1 Sound(0,freq*10,8,15)ø      IF y=0 OR y=23 OR x=0 OR x=19ø      THEN EXITø      FIøø      FOR loop=1 TO 750ø      DOø      ODøø   ODøø   plot1(x,y,f)ø   Sndrst()øøRETURNøøPROC titles()ø   BYTE x,y,i,c=[0],a,bøø   scrninit()øø   color = 12ø   x=2 y=8ø   Plot(x+4,y) Drawto(x,y) Drawto(x,y+6) ø   Drawto(x+4,y+6) Drawto(x+4,y+3) Drawto(x+2,y+3)øø   Plot(x+10,y) Drawto(x+6,y) Drawto(x+6,y+6)ø   Drawto(x+10,y+6) Plot(x+7,y+3) Plot(x+8,y+3)ø ø   Plot(x+12,y+6) Drawto(x+12,y) Drawto(x+14,y+2)ø   Drawto(x+16,y) Drawto(x+16,y+6)  ø   ø   rdmize()øø   FOR i = 1 TO 120ø   DOø      Sound(0,255,10,i RSH 3)ø      Sound(1,254,10,i RSH 3)ø      c ==+ 3   Poke(709,c)ø      tick()ø   OD øø   Poke(709,120)øø   Sndrst()øø   FOR i = 0 TO 118ø   DOø      a = bx(i)    b = by(i)ø      IF locate1(a+x,b+y)<>0ø      THEN gwarp(a+x,b+y)ø      FIø     ø   ODøøRETURNøøøPROC game()ø   CARD numøø      Close(1)ø      Open(1,"K:",4,1)øø   titles()ø   øDOø   intro()ø   reset()ø   DOøø   IF playto>1 ø   THEN num = 4+(score(winning)*maxbots/(playto-1))ø   ELSE num = 4+maxbotsø   FIøø   round(num)ø   num ==+ 1ø   UNTIL score(winner-1)=playtoø   ODøø   announce(winner-1)ø   UNTIL playagain()=0øODø   Close(1)øRETURNø